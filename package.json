    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "prettier": "^3.9.4",
    "typescript": "^5.9.3",
    "vite": "^8.1.3",
